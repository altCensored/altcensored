#: templates/about/about_index.html:123
msgid ""
"This website uses browser cookies to authenticate registered users. This "
"data consists of"
msgstr ""
"Ce site Web utilise des cookies de navigateur pour authentifier les utilisateurs enregistrés. Ces "
"données se composent de"

